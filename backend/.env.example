# Application
APP_NAME=IşıkSchedule
APP_ENV=development
DEBUG=true

# REQUIRED in production. Leaving this at the default will fail startup
# when APP_ENV=production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Auth / JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Default is SQLite for single-node sync-first deployment. Swap to
# postgresql+psycopg://... if/when B2 (Opsiyonel Backlog) is executed.
DATABASE_URL=sqlite:///./data.db

# Redis (only used if/when B1 is executed; unused today)
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS (comma-separated). In production, set explicit origins only.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting (reserved; not wired yet)
RATE_LIMIT_PER_MINUTE=100

# Job Settings
JOB_TIMEOUT_SECONDS=300
MAX_SCHEDULES_PER_JOB=50

# Admin bootstrap (created on first startup if no user with this email exists).
# REQUIRED in production; development falls back to built-in defaults with a warning.
ADMIN_EMAIL=
ADMIN_PASSWORD=
