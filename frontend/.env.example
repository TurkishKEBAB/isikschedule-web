# Local development can omit this; next.config.js falls back to http://localhost:8000
# when NODE_ENV is not production.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production is fail-fast: NEXT_PUBLIC_API_URL is required.
# Chosen model: absolute backend API domain + backend CORS.
# Frontend: https://isikschedule.yigiokur.me
# API:      https://api.isikschedule.yigiokur.me
# NEXT_PUBLIC_API_URL=https://api.isikschedule.yigiokur.me
