      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');\n\n  #isik-landing { font-family: 'Inter', system-ui, sans-serif; }\n\n  @keyframes aurora-drift-1 { 0%,100% { transform: translate3d(0,0,0) scale(1); } 50% { transform: translate3d(8%,6%,0) scale(1.25); } }\n  @keyframes aurora-drift-2 { 0%,100% { transform: translate3d(0,0,0) scale(1.1); } 50% { transform: translate3d(-10%,8%,0) scale(0.9); } }\n  @keyframes aurora-drift-3 { 0%,100% { transform: translate3d(0,0,0) scale(1); } 50% { transform: translate3d(6%,-8%,0) scale(1.2); } }\n  @keyframes aurora-drift-4 { 0%,100% { transform: translate3d(0,0,0) scale(0.95); } 50% { transform: translate3d(-7%,-5%,0) scale(1.15); } }\n  .aurora-blob-1 { animation: aurora-drift-1 18s ease-in-out infinite; }\n  .aurora-blob-2 { animation: aurora-drift-2 22s ease-in-out infinite; }\n  .aurora-blob-3 { animation: aurora-drift-3 26s ease-in-out infinite; }\n  .aurora-blob-4 { animation: aurora-drift-4 30s ease-in-out infinite; }\n\n  @keyframes shimmer-sweep { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }\n  .shimmer { background: linear-gradient(110deg, rgba(255,255,255,0.03) 8%, rgba(255,255,255,0.10) 18%, rgba(255,255,255,0.03) 33%); background-size: 200% 100%; animation: shimmer-sweep 2.2s linear infinite; }\n\n  .grad-text { background: linear-gradient(100deg,#3B82F6 0%,#8B5CF6 45%,#F59E0B 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }\n  .magnetic { transition: transform .25s cubic-bezier(.2,.8,.2,1), box-shadow .25s ease, filter .25s ease; }\n  .magnetic:hover { transform: translateY(-2px); filter: brightness(1.08); }\n  .lift { transition: transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s ease, border-color .35s ease; }\n  .lift:hover { transform: translateY(-6px); }\n\n  @media (prefers-reduced-motion: reduce) {\n    .aurora-blob-1,.aurora-blob-2,.aurora-blob-3,.aurora-blob-4 { animation: none !important; }\n    .shimmer { animation: none !important; }\n    .magnetic, .lift { transition: none !important; }\n  }\n</style>\n\n<div id=\"isik-landing\" class=\"relative min-h-screen w-full overflow-x-hidden bg-[#0B1020] text-slate-100 antialiased\" data-kid=\"1\">\n\n  \n  <div class=\"pointer-events-none fixed inset-0 z-0 overflow-hidden\" data-kid=\"2\">\n    <div class=\"aurora-blob-1 absolute -top-40 -left-32 h-[42rem] w-[42rem] rounded-full blur-3xl\" style=\"background:radial-gradient(circle at center, rgba(30,64,175,0.40), transparent 65%)\" data-kid=\"3\"></div>\n    <div class=\"aurora-blob-2 absolute top-1/4 -right-40 h-[40rem] w-[40rem] rounded-full blur-3xl\" style=\"background:radial-gradient(circle at center, rgba(79,70,229,0.34), transparent 65%)\" data-kid=\"4\"></div>\n    <div class=\"aurora-blob-3 absolute bottom-0 left-1/4 h-[38rem] w-[38rem] rounded-full blur-3xl\" style=\"background:radial-gradient(circle at center, rgba(139,92,246,0.30), transparent 65%)\" data-kid=\"5\"></div>\n    <div class=\"aurora-blob-4 absolute top-1/2 left-1/3 h-[34rem] w-[34rem] rounded-full blur-3xl\" style=\"background:radial-gradient(circle at center, rgba(245,158,11,0.22), transparent 65%)\" data-kid=\"6\"></div>\n    <div class=\"absolute inset-0\" style=\"background:radial-gradient(ellipse at 50% 0%, transparent 40%, rgba(11,16,32,0.6) 100%)\" data-kid=\"7\"></div>\n  </div>\n\n  \n  <header class=\"sticky top-0 z-50\" data-kid=\"8\">\n    <div class=\"mx-auto mt-4 max-w-7xl px-4 sm:px-6\" data-kid=\"9\">\n      <div class=\"flex h-16 items-center justify-between rounded-2xl border border-white/10 bg-white/[0.05] px-4 shadow-2xl shadow-black/40 backdrop-blur-xl ring-1 ring-inset ring-white/10\" data-kid=\"10\">\n        <a href=\"#\" class=\"flex items-center gap-2.5\" data-kid=\"11\">\n          <div class=\"flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-[#0018A8] to-[#3B82F6] shadow-lg shadow-blue-500/30\" data-kid=\"12\">\n            <i data-lucide=\"graduation-cap\" class=\"h-5 w-5 text-white\" data-kid=\"13\"></i>\n          </div>\n          <span class=\"text-lg font-bold tracking-tight text-white\" data-kid=\"14\">IşıkSchedule</span>\n        </a>\n        <nav class=\"flex items-center gap-2\" data-kid=\"15\">\n          <div class=\"flex items-center gap-0.5 rounded-lg border border-white/10 bg-white/[0.04] p-0.5\" data-kid=\"16\">\n            <button class=\"rounded-md bg-[#3B82F6]/20 px-2.5 py-1.5 text-xs font-semibold text-[#93c5fd]\" data-kid=\"17\">TR</button>\n            <button class=\"rounded-md px-2.5 py-1.5 text-xs font-medium text-slate-400 hover:text-slate-200\" data-kid=\"18\">EN</button>\n          </div>\n          <button class=\"rounded-lg px-3 py-2 text-xs font-medium text-slate-300 hover:bg-white/5 hover:text-white\" data-kid=\"19\">Giriş</button>\n          <button class=\"magnetic inline-flex items-center gap-1.5 rounded-lg bg-gradient-to-r from-[#0018A8] to-[#3B82F6] px-3.5 py-2 text-xs font-semibold text-white shadow-lg shadow-blue-500/30\" data-kid=\"20\">\n            <i data-lucide=\"calendar\" class=\"h-3.5 w-3.5\" data-kid=\"21\"></i> Başla\n          </button>\n        </nav>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"relative z-10 mx-auto max-w-7xl px-4 pt-16 pb-24 sm:px-6 lg:pt-24\" data-kid=\"22\">\n    <div class=\"grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]\" data-kid=\"23\">\n      \n      <div data-reveal class=\"text-center lg:text-left\" data-kid=\"24\">\n        <div class=\"mb-7 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/25 bg-[#3B82F6]/10 px-4 py-1.5 text-sm font-medium text-[#93c5fd] backdrop-blur-md\" data-kid=\"25\">\n          <i data-lucide=\"sparkles\" class=\"h-3.5 w-3.5\" data-kid=\"26\"></i>\n          Işık Üniversitesi öğrencileri için tasarlandı\n        </div>\n\n        <h1 class=\"mb-6 text-5xl font-black leading-[1.04] tracking-tight text-white sm:text-6xl lg:text-7xl\" data-kid=\"27\">\n          <span class=\"block\" data-kid=\"28\">Ders Programını</span>\n          <span class=\"grad-text block\" data-kid=\"29\">Saniyeler İçinde Oluştur</span>\n        </h1>\n\n        <p class=\"mx-auto mb-9 max-w-xl text-base leading-relaxed text-slate-400 lg:mx-0 lg:text-lg\" data-kid=\"30\">\n          Derslerini seç; ECTS limitini, çakışma toleransını ve istemediğin saatleri ayarla. Planlayıcı uygun program seçeneklerini oluştursun.\n        </p>\n\n        <div class=\"flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center lg:justify-start\" data-kid=\"31\">\n          <button class=\"magnetic group inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-[#0018A8] via-[#1E40AF] to-[#3B82F6] px-8 py-4 text-base font-semibold text-white shadow-xl shadow-blue-500/30\" data-kid=\"32\">\n            Hemen Başla\n            <i data-lucide=\"arrow-right\" class=\"h-5 w-5 transition-transform group-hover:translate-x-1\" data-kid=\"33\"></i>\n          </button>\n          <button class=\"magnetic inline-flex items-center justify-center gap-2 rounded-2xl border border-white/12 bg-white/[0.05] px-8 py-4 text-base font-semibold text-slate-100 backdrop-blur-md hover:bg-white/[0.08]\" data-kid=\"34\">\n            Excel Yükle\n            <i data-lucide=\"chevron-right\" class=\"h-4 w-4\" data-kid=\"35\"></i>\n          </button>\n        </div>\n\n        <div class=\"mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-slate-400 lg:justify-start\" data-kid=\"36\">\n          <span class=\"inline-flex items-center gap-1.5\" data-kid=\"37\"><i data-lucide=\"check-circle-2\" class=\"h-4 w-4 text-emerald-400\" data-kid=\"38\"></i> Hızlı Program Üretimi</span>\n          <span class=\"inline-flex items-center gap-1.5\" data-kid=\"39\"><i data-lucide=\"check-circle-2\" class=\"h-4 w-4 text-emerald-400\" data-kid=\"40\"></i> Kolay Dışa Aktarım</span>\n        </div>\n      </div>\n\n      \n      <div data-reveal class=\"relative mx-auto w-full max-w-xl\" data-kid=\"41\">\n        <div class=\"absolute -inset-6 rounded-[40px] bg-gradient-to-br from-[#3B82F6]/20 via-[#8B5CF6]/15 to-[#F59E0B]/15 blur-2xl\" data-kid=\"42\"></div>\n\n        <div class=\"relative rounded-[32px] border border-white/10 bg-white/[0.05] p-5 shadow-2xl shadow-black/50 backdrop-blur-xl ring-1 ring-inset ring-white/10\" data-kid=\"43\">\n          <div class=\"mb-4 flex items-center justify-between px-1\" data-kid=\"44\">\n            <div class=\"flex items-center gap-2\" data-kid=\"45\">\n              <span class=\"h-2.5 w-2.5 rounded-full bg-[#3B82F6]\" data-kid=\"46\"></span>\n              <span class=\"text-sm font-semibold text-white\" data-kid=\"47\">Haftalık Program</span>\n            </div>\n            <span class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-slate-500\" data-kid=\"48\">Canlı Önizleme</span>\n          </div>\n\n          \n          <div class=\"overflow-hidden rounded-2xl border border-white/10 bg-[#0E1428]/70\" data-kid=\"49\">\n            <div class=\"grid grid-cols-[44px_repeat(5,1fr)] border-b border-white/10 text-center text-[11px] font-semibold uppercase tracking-wider text-slate-400\" data-kid=\"50\">\n              <div class=\"py-2\" data-kid=\"51\"></div>\n              <div class=\"py-2\" data-kid=\"52\">Pzt</div><div class=\"py-2\" data-kid=\"53\">Sal</div><div class=\"py-2\" data-kid=\"54\">Çar</div><div class=\"py-2\" data-kid=\"55\">Per</div><div class=\"py-2\" data-kid=\"56\">Cum</div>\n            </div>\n            <div id=\"preview-grid\" class=\"divide-y divide-white/[0.05]\" data-kid=\"57\">\n              \n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"58\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"59\">08:30</div>\n                <div class=\"p-1\" data-kid=\"60\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"61\">MAT101</div></div>\n                <div class=\"p-1\" data-kid=\"62\"></div>\n                <div class=\"p-1\" data-kid=\"63\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"64\">ENG101</div></div>\n                <div class=\"p-1\" data-kid=\"65\"></div>\n                <div class=\"p-1\" data-kid=\"66\"><div class=\"course-cell rounded-md border border-[#10B981]/30 bg-[#10B981]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"67\">CS100 PS</div></div>\n              </div>\n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"68\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"69\">09:30</div>\n                <div class=\"p-1\" data-kid=\"70\"></div>\n                <div class=\"p-1\" data-kid=\"71\"><div class=\"course-cell rounded-md border border-[#8B5CF6]/30 bg-[#8B5CF6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"72\">PHY102 Lab</div></div>\n                <div class=\"p-1\" data-kid=\"73\"></div>\n                <div class=\"p-1\" data-kid=\"74\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"75\">MAT101</div></div>\n                <div class=\"p-1\" data-kid=\"76\"></div>\n              </div>\n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"77\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"78\">10:30</div>\n                <div class=\"p-1\" data-kid=\"79\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"80\">CS201</div></div>\n                <div class=\"p-1\" data-kid=\"81\"></div>\n                <div class=\"p-1\" data-kid=\"82\"><div class=\"course-cell rounded-md border border-[#8B5CF6]/30 bg-[#8B5CF6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"83\">CS201 Lab</div></div>\n                <div class=\"p-1\" data-kid=\"84\"></div>\n                <div class=\"p-1\" data-kid=\"85\"></div>\n              </div>\n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"86\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"87\">11:30</div>\n                <div class=\"p-1\" data-kid=\"88\"></div>\n                <div class=\"p-1\" data-kid=\"89\"></div>\n                <div class=\"p-1\" data-kid=\"90\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"91\">ENG101</div></div>\n                <div class=\"p-1\" data-kid=\"92\"></div>\n                <div class=\"p-1\" data-kid=\"93\"><div class=\"course-cell rounded-md border border-[#10B981]/30 bg-[#10B981]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"94\">MAT101 PS</div></div>\n              </div>\n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"95\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"96\">12:30</div>\n                <div class=\"p-1\" data-kid=\"97\"><div class=\"course-cell rounded-md border border-[#8B5CF6]/30 bg-[#8B5CF6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"98\">PHY102 Lab</div></div>\n                <div class=\"p-1\" data-kid=\"99\"></div>\n                <div class=\"p-1\" data-kid=\"100\"></div>\n                <div class=\"p-1\" data-kid=\"101\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"102\">CS201</div></div>\n                <div class=\"p-1\" data-kid=\"103\"></div>\n              </div>\n              <div class=\"grid grid-cols-[44px_repeat(5,1fr)]\" data-kid=\"104\">\n                <div class=\"flex items-center justify-center border-r border-white/[0.05] py-1 text-[10px] tabular-nums text-slate-500\" data-kid=\"105\">13:30</div>\n                <div class=\"p-1\" data-kid=\"106\"></div>\n                <div class=\"p-1\" data-kid=\"107\"><div class=\"course-cell rounded-md border border-[#3B82F6]/30 bg-[#3B82F6]/85 px-1.5 py-1 text-[9px] font-semibold text-white\" data-kid=\"108\">ENG101</div></div>\n                <div class=\"p-1\" data-kid=\"109\"></div>\n                <div class=\"p-1\" data-kid=\"110\"></div>\n                <div class=\"p-1\" data-kid=\"111\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"absolute -bottom-6 -left-6 flex items-center gap-4 rounded-2xl border border-white/12 bg-[#0E1428]/85 px-5 py-4 shadow-2xl shadow-black/50 backdrop-blur-xl ring-1 ring-inset ring-white/10\" data-kid=\"112\">\n          <div data-kid=\"113\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.16em] text-slate-500\" data-kid=\"114\">Skor</p>\n            <p class=\"grad-text text-3xl font-black leading-none\" data-count=\"92\" data-kid=\"115\">0</p>\n          </div>\n          <div class=\"h-10 w-px bg-white/10\" data-kid=\"116\"></div>\n          <div data-kid=\"117\">\n            <p class=\"text-[10px] font-medium uppercase tracking-[0.16em] text-slate-500\" data-kid=\"118\">Toplam ECTS</p>\n            <p class=\"text-3xl font-black leading-none text-white\" data-count=\"28\" data-kid=\"119\">0</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative z-10 mx-auto max-w-6xl px-4 py-24 sm:px-6\" data-kid=\"120\">\n    <div data-reveal class=\"mb-16 text-center\" data-kid=\"121\">\n      <p class=\"mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-[#93c5fd]\" data-kid=\"122\">Özellikler</p>\n      <h2 class=\"text-4xl font-bold tracking-tight text-white\" data-kid=\"123\">Neden <span class=\"grad-text\" data-kid=\"124\">IşıkSchedule</span>?</h2>\n    </div>\n\n    <div class=\"grid gap-6 md:grid-cols-3\" data-kid=\"125\">\n      \n      <div data-reveal class=\"lift group rounded-[28px] bg-gradient-to-br from-white/15 via-[#3B82F6]/25 to-[#F59E0B]/25 p-[1.5px] shadow-xl shadow-black/30 hover:shadow-blue-500/20\" data-kid=\"126\">\n        <div class=\"h-full rounded-[27px] bg-[#0E1428]/90 p-7 backdrop-blur-xl\" data-kid=\"127\">\n          <div class=\"mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-500/25 to-orange-500/20 text-amber-300 ring-1 ring-inset ring-white/10\" data-kid=\"128\">\n            <i data-lucide=\"zap\" class=\"h-6 w-6\" data-kid=\"129\"></i>\n          </div>\n          <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"130\">Hızlı Program Üretimi</h3>\n          <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"131\">Ders seçeneklerini saniyeler içinde tarayıp kullanılabilir program kombinasyonlarını çıkar.</p>\n        </div>\n      </div>\n      <div data-reveal class=\"lift group rounded-[28px] bg-gradient-to-br from-white/15 via-[#8B5CF6]/25 to-[#3B82F6]/25 p-[1.5px] shadow-xl shadow-black/30 hover:shadow-violet-500/20\" data-kid=\"132\">\n        <div class=\"h-full rounded-[27px] bg-[#0E1428]/90 p-7 backdrop-blur-xl\" data-kid=\"133\">\n          <div class=\"mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-500/25 to-indigo-500/20 text-blue-300 ring-1 ring-inset ring-white/10\" data-kid=\"134\">\n            <i data-lucide=\"target\" class=\"h-6 w-6\" data-kid=\"135\"></i>\n          </div>\n          <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"136\">Esnek Tercihler</h3>\n          <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"137\">ECTS limitini ve çakışma toleransını ayarla; istemediğin saatleri kilitle ve uygun şubeyi seç.</p>\n        </div>\n      </div>\n      <div data-reveal class=\"lift group rounded-[28px] bg-gradient-to-br from-white/15 via-[#10B981]/25 to-[#3B82F6]/25 p-[1.5px] shadow-xl shadow-black/30 hover:shadow-emerald-500/20\" data-kid=\"138\">\n        <div class=\"h-full rounded-[27px] bg-[#0E1428]/90 p-7 backdrop-blur-xl\" data-kid=\"139\">\n          <div class=\"mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500/25 to-teal-500/20 text-emerald-300 ring-1 ring-inset ring-white/10\" data-kid=\"140\">\n            <i data-lucide=\"download\" class=\"h-6 w-6\" data-kid=\"141\"></i>\n          </div>\n          <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"142\">Kolay Dışa Aktarım</h3>\n          <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"143\">Programını iCal olarak indir, PDF için yazdır veya paylaşılabilir link oluştur.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative z-10 mx-auto max-w-5xl px-4 py-24 sm:px-6\" data-kid=\"144\">\n    <div data-reveal class=\"mb-16 text-center\" data-kid=\"145\">\n      <p class=\"mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-[#93c5fd]\" data-kid=\"146\">Adımlar</p>\n      <h2 class=\"text-4xl font-bold tracking-tight text-white\" data-kid=\"147\">Nasıl Çalışır?</h2>\n    </div>\n\n    <div class=\"relative grid gap-10 md:grid-cols-3\" data-kid=\"148\">\n      \n      <div class=\"absolute left-0 right-0 top-7 hidden h-px bg-gradient-to-r from-transparent via-[#8B5CF6]/50 to-transparent md:block\" data-kid=\"149\"></div>\n\n      <div data-reveal class=\"relative text-center\" data-kid=\"150\">\n        <div class=\"mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-[#0E1428]/85 text-lg font-black text-[#93c5fd] shadow-lg shadow-black/40 ring-1 ring-inset ring-white/10 backdrop-blur-xl\" data-kid=\"151\">01</div>\n        <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"152\">Yükle</h3>\n        <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"153\">Excel formatındaki ders listesini yükle veya aktif global dönemi kullan.</p>\n      </div>\n      <div data-reveal class=\"relative text-center\" data-kid=\"154\">\n        <div class=\"mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-[#0E1428]/85 text-lg font-black text-[#c4b5fd] shadow-lg shadow-black/40 ring-1 ring-inset ring-white/10 backdrop-blur-xl\" data-kid=\"155\">02</div>\n        <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"156\">Seç</h3>\n        <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"157\">Derslerini seç; ECTS limitini, çakışma toleransını ve kilitli saatleri ayarla.</p>\n      </div>\n      <div data-reveal class=\"relative text-center\" data-kid=\"158\">\n        <div class=\"mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-[#0E1428]/85 text-lg font-black text-[#fcd34d] shadow-lg shadow-black/40 ring-1 ring-inset ring-white/10 backdrop-blur-xl\" data-kid=\"159\">03</div>\n        <h3 class=\"mb-2 text-lg font-semibold text-white\" data-kid=\"160\">Oluştur</h3>\n        <p class=\"text-sm leading-relaxed text-slate-400\" data-kid=\"161\">Planlayıcı uygun şube kombinasyonlarını otomatik olarak oluştursun.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"relative z-10 border-t border-white/10 px-4 py-10 sm:px-6\" data-kid=\"162\">\n    <div class=\"mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 sm:flex-row\" data-kid=\"163\">\n      <div class=\"flex items-center gap-2 text-sm text-slate-400\" data-kid=\"164\">\n        <div class=\"flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-[#0018A8] to-[#3B82F6]\" data-kid=\"165\">\n          <i data-lucide=\"graduation-cap\" class=\"h-4 w-4 text-white\" data-kid=\"166\"></i>\n        </div>\n        <span data-kid=\"167\">© 2026 IşıkSchedule</span>\n      </div>\n      <p class=\"text-center text-sm text-slate-400 sm:text-right\" data-kid=\"168\">Işık Üniversitesi öğrencileri için geliştirilmiş bağımsız bir öğrenci projesidir.</p>\n    </div>\n  </footer>\n\n  <script src=\"https://unpkg.com/lucide@latest\" data-kid=\"169\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"170\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"171\"></script>\n  <script data-kid=\"172\">\n    (function () {\n      if (window.lucide) lucide.createIcons();\n\n      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n      if (!window.gsap) return;\n      gsap.registerPlugin(ScrollTrigger);\n\n      if (reduce) {\n        gsap.set('[data-reveal]', { opacity: 1, y: 0 });\n        gsap.set('.course-cell', { opacity: 1, scale: 1 });\n        document.querySelectorAll('[data-count]').forEach(function (el) { el.textContent = el.getAttribute('data-count'); });\n        return;\n      }\n\n      // Scroll reveals\n      gsap.utils.toArray('[data-reveal]').forEach(function (el) {\n        gsap.from(el, {\n          opacity: 0, y: 32, duration: 0.7, ease: 'power3.out',\n          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none reverse' }\n        });\n      });\n\n      // Living grid staggered fill\n      gsap.set('.course-cell', { opacity: 0, scale: 0.7, transformOrigin: 'center' });\n      gsap.to('.course-cell', {\n        opacity: 1, scale: 1, duration: 0.45, ease: 'back.out(1.7)',\n        stagger: { each: 0.09, from: 'start' },\n        scrollTrigger: { trigger: '#preview-grid', start: 'top 90%' }\n      });\n\n      // Count-up badges\n      document.querySelectorAll('[data-count]').forEach(function (el) {\n        var target = parseInt(el.getAttribute('data-count'), 10) || 0;\n        var obj = { v: 0 };\n        gsap.to(obj, {\n          v: target, duration: 1.6, ease: 'power2.out', delay: 0.4,\n          onUpdate: function () { el.textContent = Math.round(obj.v); },\n          scrollTrigger: { trigger: el, start: 'top 95%' }\n        });\n      });\n    })();\n  </script>\n</div>",
