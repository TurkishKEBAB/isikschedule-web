      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n\n  .isik-root { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }\n  .isik-root *::-webkit-scrollbar { width: 6px; height: 6px; }\n  .isik-root *::-webkit-scrollbar-track { background: transparent; }\n  .isik-root *::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.25); border-radius: 3px; }\n\n  .glass { background: rgba(30,41,59,0.50); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.07); }\n  .glass-strong { background: rgba(15,23,42,0.72); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.06); }\n\n  .grad-text { background: linear-gradient(135deg,#60A5FA 0%,#A78BFA 50%,#FCD34D 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }\n\n  .grad-border { position: relative; }\n  .grad-border::before { content:''; position:absolute; inset:0; border-radius: inherit; padding:1px;\n    background: linear-gradient(135deg,#3B82F6,#8B5CF6,#F59E0B);\n    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);\n    -webkit-mask-composite: xor; mask-composite: exclude; pointer-events:none; }\n\n  .aurora-blob { position:absolute; border-radius:9999px; filter: blur(80px); opacity:0.42; will-change: transform; }\n\n  @media (prefers-reduced-motion: reduce) {\n    .aurora-blob { opacity: 0.30; }\n  }\n</style>\n\n<div class=\"isik-root relative h-[960px] w-full overflow-hidden bg-[#080d1c] text-slate-100\" data-kid=\"1\">\n\n  \n  <div class=\"absolute inset-0 z-0 overflow-hidden\" aria-hidden=\"true\" data-kid=\"2\">\n    <div class=\"aurora-blob\" id=\"blob-1\" style=\"width:620px;height:620px;top:-180px;left:-120px;background:radial-gradient(circle at center,#1E40AF,transparent 65%);\" data-kid=\"3\"></div>\n    <div class=\"aurora-blob\" id=\"blob-2\" style=\"width:560px;height:560px;top:-120px;right:-100px;background:radial-gradient(circle at center,#7C3AED,transparent 65%);\" data-kid=\"4\"></div>\n    <div class=\"aurora-blob\" id=\"blob-3\" style=\"width:520px;height:520px;bottom:-220px;left:38%;background:radial-gradient(circle at center,#F59E0B,transparent 68%);opacity:0.22;\" data-kid=\"5\"></div>\n    \n    <div class=\"absolute inset-0\" style=\"background:radial-gradient(120% 90% at 50% 40%, rgba(8,13,28,0.55), rgba(8,13,28,0.86));\" data-kid=\"6\"></div>\n  </div>\n\n  \n  <div class=\"relative z-10 flex h-full flex-col\" data-kid=\"7\">\n\n    \n    <header class=\"reveal flex-shrink-0 glass-strong px-4 py-2.5\" data-kid=\"8\">\n      <div class=\"mx-auto flex items-center gap-2.5\" data-kid=\"9\">\n        <a class=\"flex shrink-0 items-center gap-2.5\" data-kid=\"10\">\n          <span class=\"flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-isik-blue to-violet-500 shadow-lg shadow-blue-500/30\" style=\"--tw-gradient-from:#0018A8;\" data-kid=\"11\">\n            <i data-lucide=\"graduation-cap\" class=\"h-5 w-5 text-white\" data-kid=\"12\"></i>\n          </span>\n          <span class=\"leading-tight\" data-kid=\"13\">\n            <span class=\"block text-[15px] font-bold tracking-tight text-white\" data-kid=\"14\">IşıkSchedule</span>\n            <span class=\"block max-w-44 truncate text-[11px] text-slate-400\" data-kid=\"15\">Kaynak: 2024-2025 Güz</span>\n          </span>\n        </a>\n\n        <div class=\"ml-auto flex items-center gap-1.5\" data-kid=\"16\">\n          \n          <div class=\"flex items-center gap-0.5 rounded-lg border border-white/5 bg-white/5 p-0.5\" data-kid=\"17\">\n            <button class=\"rounded-md bg-blue-500/20 px-2.5 py-1.5 text-[11px] font-semibold text-blue-300 shadow-sm\" data-kid=\"18\">TR</button>\n            <button class=\"rounded-md px-2.5 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:text-slate-200\" data-kid=\"19\">EN</button>\n          </div>\n\n          \n          <div class=\"flex items-center gap-0.5 rounded-lg border border-white/5 bg-white/5 p-0.5\" data-kid=\"20\">\n            <button class=\"inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-300 transition-colors hover:bg-white/10\" title=\"Geri al\" data-kid=\"21\"><i data-lucide=\"undo-2\" class=\"h-3.5 w-3.5\" data-kid=\"22\"></i></button>\n            <button class=\"inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-500 transition-colors hover:bg-white/10\" title=\"Yinele\" data-kid=\"23\"><i data-lucide=\"redo-2\" class=\"h-3.5 w-3.5\" data-kid=\"24\"></i></button>\n          </div>\n\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"25\"><i data-lucide=\"folder-open\" class=\"h-3.5 w-3.5\" data-kid=\"26\"></i>Dosya değiştir</button>\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"27\"><i data-lucide=\"refresh-cw\" class=\"h-3.5 w-3.5\" data-kid=\"28\"></i>Kilitleri temizle</button>\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"29\"><i data-lucide=\"x\" class=\"h-3.5 w-3.5\" data-kid=\"30\"></i>Seçimi temizle</button>\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"31\"><i data-lucide=\"download\" class=\"h-3.5 w-3.5\" data-kid=\"32\"></i>Dışa aktar</button>\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"33\"><i data-lucide=\"bar-chart-3\" class=\"h-3.5 w-3.5\" data-kid=\"34\"></i>İstatistikler</button>\n          <button class=\"inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" title=\"Klavye kısayolları\" data-kid=\"35\"><i data-lucide=\"keyboard\" class=\"h-3.5 w-3.5\" data-kid=\"36\"></i></button>\n          <button class=\"inline-flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:bg-white/5 hover:text-slate-100\" data-kid=\"37\"><i data-lucide=\"settings\" class=\"h-3.5 w-3.5\" data-kid=\"38\"></i>Ayarlar</button>\n\n          \n          <div class=\"ml-0.5 flex items-center gap-1.5 rounded-lg border border-white/5 bg-white/5 px-3 py-1.5 text-xs\" data-kid=\"39\">\n            <span id=\"cnt-courses\" class=\"font-bold grad-text\" data-kid=\"40\">6</span>\n            <span class=\"text-slate-400\" data-kid=\"41\">ders</span>\n            <span class=\"mx-0.5 text-slate-600\" data-kid=\"42\">·</span>\n            <span id=\"cnt-ects\" class=\"font-bold grad-text\" data-kid=\"43\">30</span>\n            <span class=\"text-slate-400\" data-kid=\"44\">ECTS</span>\n          </div>\n\n          \n          <button class=\"inline-flex shrink-0 items-center gap-2 rounded-lg bg-gradient-to-r from-isik-blue to-blue-500 px-4 py-2 text-xs font-semibold text-white shadow-lg shadow-blue-600/40 transition-transform hover:-translate-y-0.5\" style=\"--tw-gradient-from:#0018A8;\" data-kid=\"45\">\n            <i data-lucide=\"rocket\" class=\"h-3.5 w-3.5\" data-kid=\"46\"></i>Program oluştur\n          </button>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"flex flex-1 overflow-hidden\" data-kid=\"47\">\n\n      \n      <aside class=\"reveal flex w-80 flex-shrink-0 flex-col border-r border-white/5 bg-slate-900/30\" data-kid=\"48\">\n        <div class=\"space-y-3 border-b border-white/5 p-3\" data-kid=\"49\">\n          <div class=\"relative\" data-kid=\"50\">\n            <i data-lucide=\"search\" class=\"pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-500\" data-kid=\"51\"></i>\n            <input type=\"text\" placeholder=\"Ders ara...\" class=\"w-full rounded-lg border border-white/10 bg-slate-800/50 py-2 pl-9 pr-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition-colors focus:border-blue-400/50\" data-kid=\"52\">\n          </div>\n\n          <div class=\"flex flex-wrap gap-2\" data-kid=\"53\">\n            <button class=\"rounded-full border border-blue-400/30 bg-blue-500/15 px-2.5 py-1 text-[11px] font-medium text-blue-300\" data-kid=\"54\">Tümü</button>\n            <button class=\"rounded-full border border-white/5 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-400 transition-colors hover:text-slate-200\" data-kid=\"55\">Seçili</button>\n            <button class=\"rounded-full border border-white/5 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-400 transition-colors hover:text-slate-200\" data-kid=\"56\">Kilitli</button>\n          </div>\n\n          <div data-kid=\"57\">\n            <label class=\"mb-1.5 block text-[11px] font-medium uppercase tracking-wider text-slate-400\" data-kid=\"58\">Akademik birim</label>\n            <div class=\"relative\" data-kid=\"59\">\n              <select class=\"w-full appearance-none rounded-lg border border-white/10 bg-slate-800/50 py-2 pl-3 pr-8 text-sm text-slate-200 outline-none\" data-kid=\"60\">\n                <option data-kid=\"61\">Mühendislik ve Doğa Bilimleri Fakültesi</option>\n              </select>\n              <i data-lucide=\"chevron-down\" class=\"pointer-events-none absolute right-2.5 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-500\" data-kid=\"62\"></i>\n            </div>\n          </div>\n\n          <div class=\"grid grid-cols-2 gap-2\" data-kid=\"63\">\n            <div data-kid=\"64\">\n              <label class=\"mb-1.5 block text-[11px] font-medium uppercase tracking-wider text-slate-400\" data-kid=\"65\">Kod grubu</label>\n              <div class=\"relative\" data-kid=\"66\">\n                <select class=\"w-full appearance-none rounded-lg border border-white/10 bg-slate-800/50 py-2 pl-3 pr-7 text-sm text-slate-200 outline-none\" data-kid=\"67\"><option data-kid=\"68\">Tüm kod grupları</option></select>\n                <i data-lucide=\"chevron-down\" class=\"pointer-events-none absolute right-2 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-500\" data-kid=\"69\"></i>\n              </div>\n            </div>\n            <div data-kid=\"70\">\n              <label class=\"mb-1.5 block text-[11px] font-medium uppercase tracking-wider text-slate-400\" data-kid=\"71\">Öğretim üyesi</label>\n              <div class=\"relative\" data-kid=\"72\">\n                <select class=\"w-full appearance-none rounded-lg border border-white/10 bg-slate-800/50 py-2 pl-3 pr-7 text-sm text-slate-200 outline-none\" data-kid=\"73\"><option data-kid=\"74\">Tümü</option></select>\n                <i data-lucide=\"chevron-down\" class=\"pointer-events-none absolute right-2 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-500\" data-kid=\"75\"></i>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"flex justify-between px-1 text-[11px] text-slate-400\" data-kid=\"76\">\n            <span data-kid=\"77\"><span id=\"cnt-c2\" class=\"font-semibold text-slate-200\" data-kid=\"78\">6</span> ders seçildi</span>\n            <span data-kid=\"79\"><span id=\"cnt-e2\" class=\"font-semibold text-slate-200\" data-kid=\"80\">30</span> ECTS</span>\n          </div>\n        </div>\n\n        \n        <div class=\"flex-1 space-y-3 overflow-y-auto p-2\" data-kid=\"81\">\n\n          \n          <div class=\"space-y-1.5\" data-kid=\"82\">\n            <div class=\"flex items-center justify-between px-2 py-1 text-[11px] uppercase tracking-[0.18em] text-slate-400\" data-kid=\"83\">\n              <span class=\"font-semibold\" data-kid=\"84\">CSE</span><span class=\"tracking-normal\" data-kid=\"85\">2/4</span>\n            </div>\n\n            <button class=\"grad-border block w-full rounded-xl bg-blue-500/10 p-3 text-left\" data-kid=\"86\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"87\">\n                <span class=\"text-sm font-semibold text-white\" data-kid=\"88\">CSE301</span>\n                <span class=\"flex items-center gap-1.5\" data-kid=\"89\"><span class=\"rounded-md bg-violet-500/20 px-2 py-0.5 text-[10px] font-medium text-violet-300\" data-kid=\"90\">Lab</span><span class=\"text-[11px] text-slate-400\" data-kid=\"91\">6 ECTS</span></span>\n              </div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"92\">Algoritma Analizi</p>\n            </button>\n\n            <button class=\"grad-border block w-full rounded-xl bg-blue-500/10 p-3 text-left\" data-kid=\"93\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"94\">\n                <span class=\"text-sm font-semibold text-white\" data-kid=\"95\">CSE201</span>\n                <span class=\"flex items-center gap-1.5\" data-kid=\"96\"><span class=\"rounded-md bg-emerald-500/20 px-2 py-0.5 text-[10px] font-medium text-emerald-300\" data-kid=\"97\">PS</span><span class=\"text-[11px] text-slate-400\" data-kid=\"98\">6 ECTS</span></span>\n              </div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"99\">Veri Yapıları</p>\n            </button>\n\n            <button class=\"block w-full rounded-xl border border-transparent p-3 text-left transition-colors hover:bg-white/5\" data-kid=\"100\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"101\">\n                <span class=\"text-sm font-semibold text-white\" data-kid=\"102\">CSE302</span><span class=\"text-[11px] text-slate-400\" data-kid=\"103\">5 ECTS</span>\n              </div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"104\">İşletim Sistemleri</p>\n            </button>\n\n            <button class=\"block w-full rounded-xl border border-red-500/20 bg-red-500/5 p-3 text-left opacity-70\" data-kid=\"105\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"106\">\n                <span class=\"text-sm font-semibold text-white\" data-kid=\"107\">CSE350</span>\n                <span class=\"flex items-center gap-1.5\" data-kid=\"108\"><i data-lucide=\"lock\" class=\"h-3 w-3 text-red-400\" data-kid=\"109\"></i><span class=\"text-[11px] text-slate-400\" data-kid=\"110\">5 ECTS</span></span>\n              </div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"111\">Veritabanı Sistemleri</p>\n              <p class=\"mt-1.5 text-[10px] text-red-400/80\" data-kid=\"112\">Tüm şubeler kilitli</p>\n            </button>\n          </div>\n\n          \n          <div class=\"space-y-1.5\" data-kid=\"113\">\n            <div class=\"flex items-center justify-between px-2 py-1 text-[11px] uppercase tracking-[0.18em] text-slate-400\" data-kid=\"114\">\n              <span class=\"font-semibold\" data-kid=\"115\">MATH</span><span class=\"tracking-normal\" data-kid=\"116\">1/2</span>\n            </div>\n            <button class=\"grad-border block w-full rounded-xl bg-blue-500/10 p-3 text-left\" data-kid=\"117\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"118\"><span class=\"text-sm font-semibold text-white\" data-kid=\"119\">MATH201</span><span class=\"text-[11px] text-slate-400\" data-kid=\"120\">5 ECTS</span></div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"121\">Diferansiyel Denklemler</p>\n            </button>\n            <button class=\"block w-full rounded-xl border border-transparent p-3 text-left transition-colors hover:bg-white/5\" data-kid=\"122\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"123\"><span class=\"text-sm font-semibold text-white\" data-kid=\"124\">MATH102</span><span class=\"text-[11px] text-slate-400\" data-kid=\"125\">5 ECTS</span></div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"126\">Lineer Cebir</p>\n            </button>\n          </div>\n\n          \n          <div class=\"space-y-1.5\" data-kid=\"127\">\n            <div class=\"flex items-center justify-between px-2 py-1 text-[11px] uppercase tracking-[0.18em] text-slate-400\" data-kid=\"128\">\n              <span class=\"font-semibold\" data-kid=\"129\">PHYS</span><span class=\"tracking-normal\" data-kid=\"130\">1/1</span>\n            </div>\n            <button class=\"grad-border block w-full rounded-xl bg-blue-500/10 p-3 text-left\" data-kid=\"131\">\n              <div class=\"mb-1 flex items-center justify-between gap-3\" data-kid=\"132\"><span class=\"text-sm font-semibold text-white\" data-kid=\"133\">PHYS101</span>\n                <span class=\"flex items-center gap-1.5\" data-kid=\"134\"><span class=\"rounded-md bg-violet-500/20 px-2 py-0.5 text-[10px] font-medium text-violet-300\" data-kid=\"135\">Lab</span><span class=\"text-[11px] text-slate-400\" data-kid=\"136\">4 ECTS</span></span></div>\n              <p class=\"text-xs leading-relaxed text-slate-400\" data-kid=\"137\">Fizik I</p>\n            </button>\n          </div>\n\n          \n          <div class=\"space-y-1.5\" data-kid=\"138\">\n            <div class=\"flex items-center justify-between px-2 py-1 text-[11px] uppercase tracking-[0.18em] text-slate-400\" data-kid=\"139\">\n              <span class=\"font-semibold\" data-kid=\"140\">ENG</span><span class=\"tracking-normal\" data-kid=\"141\">1/2</span>\n            </div>\n            <button class=\"grad-border block w-full rounded-xl bg-blu